---
import { AppShell, Footer, NavBar, PageHeader, SidebarLayout } from '@knowledge-core/ui';
import '@knowledge-core/styles/global.css';
import '@knowledge-core/styles/prose.css';
import { getCollection } from 'astro:content';
import { getTranslations, locales, switchLocalePath } from '@knowledge-core/shared/i18n';
import DocsSidebar from '../components/DocsSidebar.astro';

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
    tags?: string[];
    status?: 'stable' | 'beta' | 'deprecated';
    editUrl?: string;
    pagefind?: boolean;
    prev?: boolean | { link: string; label: string };
    next?: boolean | { link: string; label: string };
  };
}

const { frontmatter } = Astro.props;
const allDocs = await getCollection('docs', ({ data }) => !data.draft);

const locale = Astro.currentLocale ?? 'en';
const t = getTranslations(locale);
const pathname = Astro.url.pathname;
const langs = locales.map((l) => ({
  locale: l,
  label: l === 'en' ? 'English' : 'Deutsch',
  href: switchLocalePath(pathname, l),
  current: l === locale,
}));

type PrevNext = boolean | { link: string; label: string } | undefined;
function resolvePrevNext(val: PrevNext): { link: string; label: string } | null {
  if (!val || val === true) return null;
  return val;
}
const prevLink = resolvePrevNext(frontmatter.prev);
const nextLink = resolvePrevNext(frontmatter.next);
---

<AppShell
  title={`${frontmatter.title} | Dokumentation`}
  description={frontmatter.description}
>
  <NavBar logo="Docs" logoHref="/" links={[]} langs={langs} />

  <SidebarLayout hasSidebar={true} hasTableOfContents={false}>
    <DocsSidebar
      slot="sidebar"
      docs={allDocs}
      currentPath={Astro.url.pathname}
    />

    <div class="max-w-4xl mx-auto">
      <PageHeader
        title={frontmatter.title}
        description={frontmatter.description}
        tags={frontmatter.tags}
        meta={{ status: frontmatter.status }}
      />

      {frontmatter.pagefind === false
        ? <div data-pagefind-ignore><article class="prose"><slot /></article></div>
        : <article class="prose" data-pagefind-body><slot /></article>
      }

      <div class="mt-12 pt-8 border-t border-border">
        <div class="flex justify-between items-center text-sm gap-4">
          <div>
            {prevLink && (
              <a href={prevLink.link} class="flex items-center gap-2 text-text-muted hover:text-primary transition-colors">
                <span aria-hidden="true">←</span>
                <span>{prevLink.label}</span>
              </a>
            )}
          </div>
          <div class="flex items-center gap-4">
            {frontmatter.editUrl && (
              <a href={frontmatter.editUrl} class="text-text-muted hover:text-primary transition-colors" target="_blank" rel="noopener noreferrer">
                {t('page.edit')}
              </a>
            )}
            {nextLink && (
              <a href={nextLink.link} class="flex items-center gap-2 text-text-muted hover:text-primary transition-colors">
                <span>{nextLink.label}</span>
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </SidebarLayout>

  <Footer slot="footer" />
</AppShell>
