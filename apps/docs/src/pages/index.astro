---
import { AppShell, Footer, NavBar } from '@knowledge-core/ui';
import '@knowledge-core/styles/global.css';
import DocsFeatures from '../components/DocsFeatures.astro';
import DocsHero from '../components/DocsHero.astro';
import DocsTechStack from '../components/DocsTechStack.astro';
---

<AppShell
  title="Knowledge Core - Documentation"
  description="A modern monorepo template for documentation and course platforms."
>
  <NavBar logo="Docs" logoHref="/" links={[]} />

  <main id="main-content" class="flex-1 mt-16">
    <DocsHero />
    <DocsFeatures />
    <DocsTechStack />

    <section class="bg-primary/5 py-16">
      <div class="container-custom text-center">
        <h2 class="text-2xl font-bold text-text mb-4">Ready to get started?</h2>
        <p class="text-text-muted mb-8 max-w-xl mx-auto">
          Start with the documentation or check out the example course to see all features in
          action.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <a href="/docs" class="btn btn-primary">View Documentation</a>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</AppShell>
