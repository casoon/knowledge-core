---
import type { CollectionEntry } from 'astro:content';
import { resolveSidebar } from '@knowledge-core/content-model/sidebar-utils';
import { sidebar as sidebarConfig } from '../config/sidebar';
import DocsSidebarGroup from './DocsSidebarGroup.astro';
import DocsSidebarLink from './DocsSidebarLink.astro';

export interface Props {
  docs: CollectionEntry<'docs'>[];
  currentPath: string;
}

const { docs, currentPath } = Astro.props;
const resolved = resolveSidebar(sidebarConfig, docs, currentPath, '/docs');
---

<nav class="p-6" aria-label="Dokumentation">
  <div class="mb-6">
    <input
      type="search"
      placeholder="Search..."
      class="input w-full"
      id="docs-search"
      aria-label="Search documentation"
    />
  </div>

  <div class="space-y-2">
    {resolved.map((entry) =>
      entry.type === 'group'
        ? <DocsSidebarGroup group={entry} />
        : <DocsSidebarLink item={entry} />
    )}
  </div>
</nav>
