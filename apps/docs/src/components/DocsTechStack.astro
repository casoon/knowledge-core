<section class="container-custom py-16">
  <h2 class="text-3xl font-bold text-text mb-12 text-center">Tech Stack</h2>
  <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
    <div class="p-6 bg-surface border border-border rounded-xl">
      <h3 class="text-lg font-semibold text-text mb-4">Frontend</h3>
      <ul class="space-y-2 text-sm text-text-muted">
        <li class="flex items-center gap-2"><span class="text-primary">→</span> Astro v6</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> Tailwind CSS v4</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> TypeScript</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> MDX</li>
      </ul>
    </div>
    <div class="p-6 bg-surface border border-border rounded-xl">
      <h3 class="text-lg font-semibold text-text mb-4">Tooling</h3>
      <ul class="space-y-2 text-sm text-text-muted">
        <li class="flex items-center gap-2"><span class="text-primary">→</span> pnpm Workspaces</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> Biome</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> Vitest</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> Pagefind</li>
      </ul>
    </div>
    <div class="p-6 bg-surface border border-border rounded-xl">
      <h3 class="text-lg font-semibold text-text mb-4">Packages</h3>
      <ul class="space-y-2 text-sm text-text-muted">
        <li class="flex items-center gap-2"><span class="text-primary">→</span> @knowledge-core/ui</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> @knowledge-core/styles</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> @knowledge-core/content-model</li>
        <li class="flex items-center gap-2"><span class="text-primary">→</span> @knowledge-core/shared</li>
      </ul>
    </div>
  </div>
</section>
