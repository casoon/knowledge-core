<section class="bg-surface-alt py-16">
  <div class="container-custom">
    <h2 class="text-2xl font-bold text-text text-center mb-12">Why Our Course Platform?</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-surface p-6 rounded-lg border border-border text-center">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 text-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-text mb-2">Progress Tracking</h3>
        <p class="text-sm text-text-muted">Keep track of your learning progress with automatic saving.</p>
      </div>
      <div class="bg-surface p-6 rounded-lg border border-border text-center">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 text-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-text mb-2">Interactive Quizzes</h3>
        <p class="text-sm text-text-muted">Test your knowledge with instant feedback and explanations.</p>
      </div>
      <div class="bg-surface p-6 rounded-lg border border-border text-center">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 text-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="font-semibold text-text mb-2">Practical Exercises</h3>
        <p class="text-sm text-text-muted">Learn by doing with graded difficulty levels.</p>
      </div>
      <div class="bg-surface p-6 rounded-lg border border-border text-center">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 text-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
          </svg>
        </div>
        <h3 class="font-semibold text-text mb-2">Cloud Sync</h3>
        <p class="text-sm text-text-muted">Sync your progress across devices.</p>
      </div>
    </div>
  </div>
</section>

<section class="container-custom py-16">
  <h2 class="text-2xl font-bold text-text text-center mb-8">Difficulty Levels</h2>
  <div class="flex flex-wrap justify-center gap-6">
    <div class="flex items-center gap-3 bg-surface-alt px-4 py-3 rounded-lg border border-border">
      <span class="w-3 h-3 rounded-full bg-success"></span>
      <div>
        <span class="font-medium text-text">Beginner</span>
        <p class="text-xs text-text-muted">No prior knowledge required</p>
      </div>
    </div>
    <div class="flex items-center gap-3 bg-surface-alt px-4 py-3 rounded-lg border border-border">
      <span class="w-3 h-3 rounded-full bg-warning"></span>
      <div>
        <span class="font-medium text-text">Intermediate</span>
        <p class="text-xs text-text-muted">Basic knowledge recommended</p>
      </div>
    </div>
    <div class="flex items-center gap-3 bg-surface-alt px-4 py-3 rounded-lg border border-border">
      <span class="w-3 h-3 rounded-full bg-error"></span>
      <div>
        <span class="font-medium text-text">Advanced</span>
        <p class="text-xs text-text-muted">Deep knowledge required</p>
      </div>
    </div>
  </div>
</section>
