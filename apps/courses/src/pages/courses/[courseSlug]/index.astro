---
import { AppShell, Footer, NavBar, ProgressBar } from '@knowledge-core/ui';
import '@knowledge-core/styles/global.css';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { groupLessonsByModule, sortLessons } from '@knowledge-core/content-model/lesson-utils';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({
    params: { courseSlug: course.data.slug },
    props: { course },
  }));
}

const { course } = Astro.props as { course: CollectionEntry<'courses'> };
const rawLessons = await getCollection('lessons', ({ data }) => {
  return data.courseSlug === course.data.slug;
});

const allLessons = sortLessons(rawLessons);
const lessonsByModule = groupLessonsByModule(allLessons);

const levelColors = {
  beginner: 'badge-success',
  intermediate: 'badge-warning',
  advanced: 'badge-error',
};
---

<AppShell
  title={`${course.data.title} | Courses`}
  description={course.data.description}
>
  <NavBar logo="Courses" logoHref="/" links={[]} />

  <main id="main-content" class="flex-1 mt-16">
    <section class="container-custom py-12">
      <!-- Course Header -->
      <div class="mb-12">
        <div class="mb-4">
          <span class:list={["badge", levelColors[course.data.level]]}>
            {course.data.level}
          </span>
        </div>
        <h1 class="text-4xl font-bold text-text mb-4">{course.data.title}</h1>
        <p class="text-lg text-text-muted mb-6">{course.data.description}</p>

        <div class="flex flex-wrap gap-4 items-center mb-6">
          <div class="flex items-center gap-2 text-text-muted">
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span
              >{Math.round(course.data.estimatedTotalMinutes / 60)} hours</span
            >
          </div>

          <div class="flex gap-2">
            {
              course.data.tags.map((tag) => (
                <span class="badge badge-primary">{tag}</span>
              ))
            }
          </div>
        </div>

        {
          allLessons.length > 0 && (
            <div class="mb-6 max-w-md">
              <ProgressBar current={0} total={allLessons.length} />
            </div>
          )
        }

        {
          allLessons.length > 0 && (
            <a
              href={`/courses/${course.data.slug}/${allLessons[0].id}`}
              class="btn btn-primary"
            >
              Start Course
            </a>
          )
        }
      </div>

      <!-- Course Content / Modules -->
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-text mb-6">Course Content</h2>

        {
          Object.keys(lessonsByModule).length === 0 ? (
            <div class="card">
              <p class="text-text-muted">
                This course has no lessons yet. Create your first lesson!
              </p>
            </div>
          ) : (
            <div class="space-y-3">
              {Object.keys(lessonsByModule).map((module, index) => (
                <details open={index === 0 || undefined} class="group card p-0 overflow-hidden">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 list-none [&::-webkit-details-marker]:hidden">
                    <div class="flex items-center gap-3">
                      <h3 class="text-base font-semibold text-text">{module}</h3>
                      <span class="text-xs text-text-muted">
                        {lessonsByModule[module].length} {lessonsByModule[module].length === 1 ? 'lesson' : 'lessons'}
                      </span>
                    </div>
                    <svg
                      class="w-4 h-4 text-text-muted transition-transform duration-200 group-open:rotate-180 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </summary>
                  <ul class="border-t border-border divide-y divide-border">
                    {lessonsByModule[module].map((lesson) => (
                      <li>
                        <a
                          href={`/courses/${course.data.slug}/${lesson.id}`}
                          class="flex items-center justify-between px-6 py-3 hover:bg-surface-alt transition-colors group/lesson"
                        >
                          <div class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-full border-2 border-border flex items-center justify-center text-xs flex-shrink-0">
                              {lesson.data.orderInModule}
                            </div>
                            <span class="text-sm text-text group-hover/lesson:text-primary transition-colors">
                              {lesson.data.title}
                            </span>
                          </div>
                          <div class="flex items-center gap-4 text-sm text-text-muted">
                            <span>{lesson.data.estimatedMinutes} min</span>
                            <svg
                              class="w-4 h-4"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"
                              />
                            </svg>
                          </div>
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</AppShell>
