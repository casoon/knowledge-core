---
import { AppShell, CourseCard, Footer, NavBar, TotalProgress } from '@knowledge-core/ui';
import '@knowledge-core/styles/global.css';
import { getCollection } from 'astro:content';
import CoursesFeatures from '../components/CoursesFeatures.astro';

const courses = await getCollection('courses');
const publishedCourses = courses.filter((course) => course.data.published);

const lessons = await getCollection('lessons');
const coursesWithLessonCount = publishedCourses.map((course) => ({
  slug: course.data.slug,
  title: course.data.title,
  lessonCount: lessons.filter((l) => l.data.courseSlug === course.data.slug).length,
}));
---

<AppShell
  title="Knowledge Core - Courses"
  description="Interactive courses with progress tracking, quizzes, and practical exercises."
>
  <NavBar logo="Courses" logoHref="/" links={[]} />

  <main id="main-content" class="flex-1 mt-16">
    <section class="container-custom py-20 text-center">
      <h1 class="text-5xl md:text-6xl font-bold text-text mb-6">
        Learn by <span class="text-primary">Doing</span>
      </h1>
      <p class="text-xl text-text-muted max-w-2xl mx-auto mb-8">
        Interactive courses with progress tracking, quizzes, and practical exercises. Learn at
        your own pace.
      </p>
      {
        coursesWithLessonCount.length > 0 && (
          <div class="max-w-md mx-auto mb-12">
            <TotalProgress courses={coursesWithLessonCount} />
          </div>
        )
      }
    </section>

    <CoursesFeatures />

    <section class="container-custom py-16">
      <h2 class="text-3xl font-bold text-text text-center mb-4">Available Courses</h2>
      <p class="text-text-muted text-center mb-12 max-w-xl mx-auto">
        Choose a course and start your learning journey. Your progress is saved automatically.
      </p>
      {
        publishedCourses.length === 0 ? (
          <div class="text-center py-16 bg-surface-alt rounded-lg border border-border">
            <svg
              class="w-16 h-16 text-text-muted mx-auto mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
              />
            </svg>
            <h3 class="text-xl font-semibold text-text mb-2">No courses available yet</h3>
            <p class="text-text-muted mb-6">
              Create your first course in the{' '}
              <code class="bg-surface px-2 py-1 rounded">content/courses</code> directory.
            </p>
          </div>
        ) : (
          <div class="max-w-5xl mx-auto">
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {publishedCourses.map((course) => (
                <CourseCard
                  title={course.data.title}
                  description={course.data.description}
                  level={course.data.level}
                  estimatedMinutes={course.data.estimatedTotalMinutes}
                  tags={course.data.tags}
                  href={`/courses/${course.data.slug}`}
                />
              ))}
            </div>
          </div>
        )
      }
    </section>

    <section class="bg-primary/5 py-16">
      <div class="container-custom text-center">
        <h2 class="text-2xl font-bold text-text mb-4">Create Your Own Courses</h2>
        <p class="text-text-muted mb-8 max-w-xl mx-auto">
          Knowledge Core makes it easy to create your own interactive courses. MDX, quizzes,
          exercises, and progress tracking included.
        </p>
        <a href="/courses" class="btn btn-primary">Browse Courses</a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</AppShell>
