---
export interface Props {
  type?: 'info' | 'success' | 'warning' | 'error';
  title?: string;
  collapsible?: boolean;
  open?: boolean;
}

const { type = 'info', title, collapsible = false, open = true } = Astro.props;

const icons = {
  info: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
  success: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
  warning: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
  </svg>`,
  error: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
};
---

{collapsible ? (
  <details
    open={open || undefined}
    class:list={[
      'group rounded-lg border-l-4 my-6',
      {
        'bg-info-bg border-info text-info': type === 'info',
        'bg-success-bg border-success text-success': type === 'success',
        'bg-warning-bg border-warning text-warning': type === 'warning',
        'bg-error-bg border-error text-error': type === 'error',
      },
    ]}
  >
    <summary class="flex cursor-pointer items-center gap-3 px-4 py-3 list-none [&::-webkit-details-marker]:hidden">
      <div class="flex-shrink-0" set:html={icons[type]} />
      <span class="flex-1 font-semibold text-sm">{title ?? type}</span>
      <svg
        class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </summary>
    <div class="px-4 pb-4 pt-1 text-sm">
      <slot />
    </div>
  </details>
) : (
  <div
    class:list={[
      'rounded-lg border-l-4 p-4 my-6',
      {
        'bg-info-bg border-info text-info': type === 'info',
        'bg-success-bg border-success text-success': type === 'success',
        'bg-warning-bg border-warning text-warning': type === 'warning',
        'bg-error-bg border-error text-error': type === 'error',
      },
    ]}
  >
    <div class="flex gap-3">
      <div class="flex-shrink-0" set:html={icons[type]} />
      <div class="flex-1">
        {title && <div class="font-semibold mb-1">{title}</div>}
        <div class="text-sm">
          <slot />
        </div>
      </div>
    </div>
  </div>
)}
