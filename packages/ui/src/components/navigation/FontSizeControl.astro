---
/**
 * FontSizeControl - Font size control for better readability
 *
 * Allows increasing/decreasing font size.
 * Saves the setting in localStorage.
 */
---

<div class="font-size-control flex items-center gap-1">
  <button
    type="button"
    id="font-size-decrease"
    class="btn btn-ghost p-1.5 text-text-muted hover:text-text"
    aria-label="Decrease font size"
    title="Decrease font size"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M20 12H4"></path>
    </svg>
  </button>

  <span
    id="font-size-indicator"
    class="text-xs text-text-muted w-8 text-center font-mono">100%</span
  >

  <button
    type="button"
    id="font-size-increase"
    class="btn btn-ghost p-1.5 text-text-muted hover:text-text"
    aria-label="Increase font size"
    title="Increase font size"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 4v16m8-8H4"></path>
    </svg>
  </button>
</div>

<script>
  import { safeGetItem, safeSetItem } from "../../scripts/storage";

  const STORAGE_KEY = "font-size";
  const MIN_SIZE = 80;
  const MAX_SIZE = 150;
  const STEP = 10;
  const DEFAULT_SIZE = 100;

  function getCurrentSize(): number {
    const stored = safeGetItem(STORAGE_KEY);
    return stored ? parseInt(stored, 10) : DEFAULT_SIZE;
  }

  function applySize(size: number): void {
    document.documentElement.style.fontSize = size + "%";
    const indicator = document.getElementById("font-size-indicator");
    const decreaseBtn = document.getElementById("font-size-decrease") as HTMLButtonElement | null;
    const increaseBtn = document.getElementById("font-size-increase") as HTMLButtonElement | null;

    if (indicator) indicator.textContent = size + "%";
    if (decreaseBtn) {
      decreaseBtn.disabled = size <= MIN_SIZE;
      decreaseBtn.classList.toggle("opacity-30", size <= MIN_SIZE);
    }
    if (increaseBtn) {
      increaseBtn.disabled = size >= MAX_SIZE;
      increaseBtn.classList.toggle("opacity-30", size >= MAX_SIZE);
    }
    safeSetItem(STORAGE_KEY, size.toString());
  }

  function initFontSizeControl(): void {
    applySize(getCurrentSize());

    document.getElementById("font-size-decrease")?.addEventListener("click", () => {
      const current = getCurrentSize();
      if (current > MIN_SIZE) applySize(current - STEP);
    });

    document.getElementById("font-size-increase")?.addEventListener("click", () => {
      const current = getCurrentSize();
      if (current < MAX_SIZE) applySize(current + STEP);
    });
  }

  document.addEventListener("astro:page-load", initFontSizeControl);
</script>
